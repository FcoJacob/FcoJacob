# Environment Variables
# Copy this file to .env and fill in values

# Convex
# Local development — used at build time in nuxt.config.ts
CONVEX_URL=https://<your-deployment>.convex.cloud

# Vercel (production/preview) — overrides runtimeConfig.public.convex.url at runtime
# Set this in the Vercel project dashboard under Settings > Environment Variables
NUXT_PUBLIC_CONVEX_URL=https://<your-deployment>.convex.cloud

# Auth (nuxt-auth-utils) — REQUIRED
# Generate a random 32+ char string: openssl rand -base64 32
NUXT_SESSION_PASSWORD=

# OAuth - Google (https://console.cloud.google.com/apis/credentials)
NUXT_OAUTH_GOOGLE_CLIENT_ID=
NUXT_OAUTH_GOOGLE_CLIENT_SECRET=

# Admin whitelist — comma-separated emails allowed to access /admin
NUXT_ADMIN_EMAILS=f.j.sarmiento.perez@gmail.com
