# Environment Variables
# Copy this file to .env and fill in values

# Convex
# NUXT_CONVEX_URL=

# Auth (nuxt-auth-utils) — REQUIRED
# Generate a random 32+ char string: openssl rand -base64 32
NUXT_SESSION_PASSWORD=

# OAuth - Google (https://console.cloud.google.com/apis/credentials)
NUXT_OAUTH_GOOGLE_CLIENT_ID=
NUXT_OAUTH_GOOGLE_CLIENT_SECRET=

# OAuth - LinkedIn (https://www.linkedin.com/developers/apps)
NUXT_OAUTH_LINKEDIN_CLIENT_ID=
NUXT_OAUTH_LINKEDIN_CLIENT_SECRET=
